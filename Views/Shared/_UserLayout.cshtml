@{
    var currentController = ViewContext.RouteData.Values["controller"]?.ToString();
    var currentAction = ViewContext.RouteData.Values["action"]?.ToString();
    var isLoggedIn = Context.Session.GetString("UserName") != null;
}

<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - FreshMart</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>
    <header class="site-header">
        <a class="brand" asp-controller="Home" asp-action="Index">🛒 FreshMart</a>
        <nav class="fresh-menu">
            <a class="@(currentController == "Home" ? "active" : "")" asp-controller="Home" asp-action="Index">Ürünler</a>
            <a class="@(currentController == "Cart" ? "active" : "")" asp-controller="Cart" asp-action="Index">Sepet</a>
            <a class="@(currentController == "Profile" ? "active" : "")" asp-controller="Profile" asp-action="Index">Profil</a>

            @if (isLoggedIn)
            {
                <a class="@(currentController == "Admin" || currentController == "AdminProducts" ? "active" : "")" asp-controller="Admin" asp-action="Index">Admin Panel</a>
            }

            @if (!isLoggedIn)
            {
                <a class="cart-pill @(currentController == "Account" && currentAction == "Login" ? "active" : "")" asp-controller="Account" asp-action="Login">Giriş</a>
            }
            else
            {
                <a class="cart-pill" asp-controller="Account" asp-action="Logout">Çıkış</a>
            }
        </nav>
    </header>

    <main class="page-shell">
        @if (TempData["Success"] != null)
        {
            <div class="alert alert-success m-3">@TempData["Success"]</div>
        }
        @if (TempData["Error"] != null)
        {
            <div class="alert alert-danger m-3">@TempData["Error"]</div>
        }

        @RenderBody()
    </main>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
