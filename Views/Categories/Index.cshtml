@model List<Category>

@{
    Layout = Context.Session.GetString("Role") == "Admin" ? "_AdminLayout" : "_UserLayout";
    ViewData["Title"] = "Kategoriler";
}

<section class="fresh-panel">
    <div class="fresh-topbar">
        <a class="brand" asp-controller="Home" asp-action="Index">FreshMart - Kategoriler</a>
        @if (Context.Session.GetString("Role") == "Admin")
        {
            <a class="cart-pill" asp-action="Create">+ Yeni Kategori</a>
        }
    </div>

    <div class="panel-body">
        <h1 class="h5 mb-3">Tüm Kategoriler</h1>
        <table class="fresh-table">
            <thead>
                <tr>
                    <th>#</th>
                    <th>Kategori Adı</th>
                    <th>Ürün Sayısı</th>
                    <th>Durum</th>
                    <th>İşlemler</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var category in Model)
                {
                    <tr>
                        <td>@category.Id</td>
                        <td>@GetIcon(category.Name) @category.Name</td>
                        <td>@category.Products.Count ürün</td>
                        <td><span class="mini-label">Aktif</span></td>
                        <td>
                            <a class="btn-soft" asp-action="Details" asp-route-id="@category.Id">Detay</a>
                            @if (Context.Session.GetString("Role") == "Admin")
                            {
                                <a class="btn-outline-fresh" asp-action="Edit" asp-route-id="@category.Id">Düzenle</a>
                                <a class="btn btn-sm btn-outline-danger" asp-action="Delete" asp-route-id="@category.Id">Sil</a>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</section>

@functions {
    string GetIcon(string name)
    {
        if (name.Contains("Süt", StringComparison.OrdinalIgnoreCase)) return "🍼";
        if (name.Contains("Atıştır", StringComparison.OrdinalIgnoreCase)) return "🍫";
        if (name.Contains("Fırın", StringComparison.OrdinalIgnoreCase)) return "🍞";
        return "🥬";
    }
}
