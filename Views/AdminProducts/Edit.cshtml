@model ProductFormViewModel

@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Ürün Düzenle";
}

<div class="fresh-panel">
    <div class="fresh-topbar">
        <a class="brand" asp-action="Index">← Ürünlere Dön</a>
        <strong>Ürün Düzenle</strong>
    </div>

    <div class="panel-body">
        <div class="alert alert-warning py-2">
            Düzenleniyor: <strong>@Model.Name</strong> (ID: @Model.Id)
        </div>

        <form asp-action="Edit" method="post">
            <input type="hidden" asp-for="Id" />
            <div class="detail-grid">
                <div>
                    <div class="mb-3">
                        <label asp-for="Name" class="form-label">Ürün Adı</label>
                        <input asp-for="Name" class="form-control" />
                        <span asp-validation-for="Name" class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="CategoryId" class="form-label">Kategori</label>
                        <select asp-for="CategoryId" asp-items="Model.Categories" class="form-select">
                            <option value="0">Kategori seçin</option>
                        </select>
                        <span asp-validation-for="CategoryId" class="text-danger"></span>
                    </div>

                    <div class="row">
                        <div class="col mb-3">
                            <label asp-for="Price" class="form-label">Fiyat</label>
                            <input asp-for="Price" class="form-control" />
                            <span asp-validation-for="Price" class="text-danger"></span>
                        </div>
                        <div class="col mb-3">
                            <label asp-for="Stock" class="form-label">Stok</label>
                            <input asp-for="Stock" class="form-control" />
                            <span asp-validation-for="Stock" class="text-danger"></span>
                        </div>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Description" class="form-label">Açıklama</label>
                        <textarea asp-for="Description" class="form-control" rows="4"></textarea>
                        <span asp-validation-for="Description" class="text-danger"></span>
                    </div>
                </div>

                <div>
                    <label asp-for="ImageUrl" class="form-label">Mevcut Görsel</label>
                    <div class="detail-art mb-2">🍏</div>
                    <input asp-for="ImageUrl" class="form-control mb-3" />

                    <div class="d-flex gap-2">
                        <a class="btn btn-outline-danger flex-fill" asp-action="Delete" asp-route-id="@Model.Id">Ürünü Sil</a>
                        <button type="submit" class="btn-fresh flex-fill">Güncelle</button>
                    </div>
                </div>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
