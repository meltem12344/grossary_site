@model List<Product>

@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Ürün Yönetimi";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <div>
        <h1 class="h5 mb-1">Ürün Yönetimi</h1>
        <p class="text-muted mb-0">Ürün ekleme, silme, güncelleme, fiyat ve stok işlemleri.</p>
    </div>
    <a class="btn-fresh" asp-action="Create">+ Yeni Ürün</a>
</div>

<table class="fresh-table">
    <thead>
        <tr>
            <th>Ürün</th>
            <th>Tür</th>
            <th>Fiyat</th>
            <th>Stok</th>
            <th>Açıklama</th>
            <th>İşlemler</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var product in Model)
        {
            <tr>
                <td>
                    <span class="cart-mini-art art-green">
                        <img src="@ProductImageHelper.GetImage(product)" alt="@product.Name" />
                    </span>
                    <strong>@product.Name</strong>
                </td>
                <td><span class="mini-label">@product.Category?.Name</span></td>
                <td><strong>@product.Price.ToString("0.00") TL / kg</strong></td>
                <td>@product.Stock kg</td>
                <td>@product.Description</td>
                <td>
                    <a class="btn-soft" asp-action="Details" asp-route-id="@product.Id">Detay</a>
                    <a class="btn-outline-fresh" asp-action="Edit" asp-route-id="@product.Id">Düzenle</a>
                    <a class="btn btn-sm btn-outline-danger" asp-action="Delete" asp-route-id="@product.Id">Sil</a>
                </td>
            </tr>
        }
    </tbody>
</table>
