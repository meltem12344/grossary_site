@model List<Product>

@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Ürünler";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h1 class="h5 mb-0">Ürün Yönetimi</h1>
    <a class="btn-fresh" asp-action="Create">+ Yeni Ürün</a>
</div>

<table class="fresh-table">
    <thead>
        <tr>
            <th>Ürün</th>
            <th>Kategori</th>
            <th>Fiyat</th>
            <th>Stok</th>
            <th>Durum</th>
            <th>İşlemler</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var product in Model)
        {
            <tr>
                <td><strong>@product.Name</strong></td>
                <td>@product.Category?.Name</td>
                <td>@product.Price.ToString("0.00") TL / @GetUnit(product)</td>
                <td>@product.Stock @GetUnit(product)</td>
                <td><span class="mini-label">Aktif</span></td>
                <td>
                    <a class="btn-soft" asp-action="Details" asp-route-id="@product.Id">Detay</a>
                    <a class="btn-outline-fresh" asp-action="Edit" asp-route-id="@product.Id">Düzenle</a>
                    <a class="btn btn-sm btn-outline-danger" asp-action="Delete" asp-route-id="@product.Id">Sil</a>
                </td>
            </tr>
        }
    </tbody>
</table>

@functions {
    string GetUnit(Product product)
    {
        if (product.Category?.Name.Contains("Meyve", StringComparison.OrdinalIgnoreCase) == true ||
            product.Category?.Name.Contains("Sebze", StringComparison.OrdinalIgnoreCase) == true)
        {
            return "kg";
        }

        return "adet";
    }
}
