@model ProductFormViewModel

@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Ürün Ekle";
}

<div class="fresh-panel">
    <div class="fresh-topbar">
        <a class="brand" asp-action="Index">← Ürünlere Dön</a>
        <strong>Yeni Ürün Ekle</strong>
    </div>

    <div class="panel-body">
        <form asp-action="Create" method="post">
            <div class="detail-grid">
                <div>
                    <div class="mb-3">
                        <label asp-for="Name" class="form-label">Ürün Adı</label>
                        <input asp-for="Name" class="form-control" placeholder="Örn: Kırmızı Elma" />
                        <span asp-validation-for="Name" class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="CategoryId" class="form-label">Ürün Türü</label>
                        <select asp-for="CategoryId" asp-items="Model.Categories" class="form-select">
                            <option value="0">Meyve veya sebze seçin</option>
                        </select>
                        <span asp-validation-for="CategoryId" class="text-danger"></span>
                    </div>

                    <div class="row">
                        <div class="col mb-3">
                            <label asp-for="Price" class="form-label">Fiyat (TL / kg)</label>
                            <input asp-for="Price" class="form-control" inputmode="decimal" />
                            <span asp-validation-for="Price" class="text-danger"></span>
                            <small class="text-muted">Örnek: 38,90</small>
                        </div>
                        <div class="col mb-3">
                            <label asp-for="Stock" class="form-label">Stok (kg)</label>
                            <input asp-for="Stock" class="form-control" />
                            <span asp-validation-for="Stock" class="text-danger"></span>
                        </div>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Description" class="form-label">Açıklama</label>
                        <textarea asp-for="Description" class="form-control" rows="4" placeholder="Ürün hakkında kısa bilgi..."></textarea>
                        <span asp-validation-for="Description" class="text-danger"></span>
                    </div>
                </div>

                <div>
                    <label asp-for="ImageUrl" class="form-label">Görsel URL</label>
                    <div class="detail-art detail-photo mb-3">
                        <img id="imagePreview" class="detail-image" src="@ProductImageHelper.GetImage(Model.Name, Model.ImageUrl)" alt="Ürün görseli" />
                    </div>
                    <input asp-for="ImageUrl" class="form-control" placeholder="İsteğe bağlı görsel URL" />

                    <div class="summary-box mt-3">
                        <strong>Admin notu</strong>
                        <p class="mb-0 mt-2">Bu panelden ürün fiyatı, stok miktarı ve ürün türü yönetilir. Bütün ürünler kg üzerinden satılır.</p>
                    </div>

                    <div class="d-flex gap-2 mt-3">
                        <a class="btn-outline-fresh flex-fill text-center" asp-action="Index">İptal</a>
                        <button type="submit" class="btn-fresh flex-fill">Kaydet</button>
                    </div>
                </div>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        if (window.jQuery && $.validator) {
            $.validator.methods.number = function (value, element) {
                return this.optional(element) || /^-?\d+([,.]\d+)?$/.test(value);
            };
        }

        const imageInput = document.getElementById('ImageUrl');
        const imagePreview = document.getElementById('imagePreview');

        imageInput.addEventListener('input', function () {
            const url = imageInput.value.trim();
            if (url.length > 0) {
                imagePreview.src = url;
            }
        });
    </script>
}
